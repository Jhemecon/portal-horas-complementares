# URL Base da API RM TOTVS
VITE_API_BASE_URL=http://ws.seculomanaus.com.br:8051/

# Configurações do Adyen (Pagamento com Cartão)
VITE_ADYEN_CLIENT_KEY=your_adyen_client_key
VITE_ADYEN_ENVIRONMENT=test

# YouTube Data API v3 (para buscar vídeos mais recentes)
# Obtenha sua API key em: https://console.developers.google.com/
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here

# Configurações Gerais
VITE_APP_NAME=Portal CIESA
VITE_APP_VERSION=2.0.0

# Debug Mode (development only)
VITE_DEBUG_MODE=true

# Ollama Base URL (BACKEND - para Chat RAG)
# Para desenvolvimento local: http://localhost:11434
# Para Easypanel: http://$(PROJECT_NAME)_ollama:11434
OLLAMA_BASE_URL=http://localhost:11434

DB_USER=postgres
DB_PASSWORD=3521c6613186fefbc99f
DB_NAME=seculo
DB_HOST=seculo_db
DB_PORT=5432
DB_CONNECTION_URL=postgres://postgres:cmsseculo@seculo_db:5432/seculo?sslmode=disable

# SMTP Email Configuration (Gmail)
# Para usar Gmail, habilite "App Passwords" na conta Google
# Vá em: Google Account > Security > 2-Step Verification > App passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
